// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id        String   @id @default(uuid())
  name      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  sites     Site[]
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  firstName   String
  lastName    String
  email       String   @unique
  jobTitle    String?
  companyname String?
  mobile      String
  password    String
  role        Role     @default(worker)
  accessMode  AccessMode @default(standard)
  allowedPages Json?
  active      Boolean  @default(true)
  emailVerified Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lastLoginAt DateTime?
  lastSeenAt  DateTime?
  
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  @@index([clientId])

  managedSites Site[] @relation("SitePrimaryManager")
  siteManagerAssignments SiteManager[]
  
  createdForms  Form[]
  submittedResponses FormResponse[]
  uploadedDocuments SiteDocument[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  savedSignatures SavedSignature[]
}

model SavedSignature {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("")
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model EmailVerificationToken {
  id           String    @id @default(uuid())
  tokenHash    String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  usedAt       DateTime?
  otpHash      String?
  otpExpiresAt DateTime?
  kind         String    @default("standard")
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([kind])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetAttempt {
  id        String   @id @default(uuid())
  emailHash String
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([emailHash, createdAt])
  @@index([ipHash, createdAt])
}

model Site {
  id        String   @id @default(uuid())
  name      String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])

  managerId String?
  manager   User?   @relation("SitePrimaryManager", fields: [managerId], references: [id])

  siteManagers SiteManager[]

  documents  SiteDocument[]
  subfolders SiteSubfolder[]
}

model SiteSubfolder {
  id        String   @id @default(uuid())
  name      String
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents SiteDocument[]

  @@index([siteId])
}

model SiteManager {
  siteId String
  userId String
  site   Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([siteId, userId])
  @@index([userId])
}

model Form {
  id             String   @id @default(uuid())
  title          String   @default("Untitled Form")
  titleColor     String   @default("#000000")
  titleAlignment String   @default("left")
  fields         Json     // Stores the array of form fields
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  responses FormResponse[]
}

model FormResponse {
  id          String   @id @default(uuid())
  answers     Json     // Stores the answers object
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formId String
  form   Form   @relation(fields: [formId], references: [id])

  submittedById String?
  submittedBy   User?   @relation(fields: [submittedById], references: [id])

  @@index([createdAt])
  @@index([category])
  @@index([submittedById])
  @@index([formId])
  @@index([submittedById, createdAt])
}

enum Role {
  superadmin
  company_admin
  site_manager
  supervisor
  worker
}

enum AccessMode {
  standard
  view_only
}

model SiteDocument {
  id          String   @id @default(uuid())
  title       String
  type        String // PDF, DOC, etc.
  version     String
  url         String
  size        String
  category    String // rams, friday-pack, etc.
  tags        String?
  validFrom   String?
  validUntil  String
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  subfolderId String?
  subfolder   SiteSubfolder? @relation(fields: [subfolderId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
