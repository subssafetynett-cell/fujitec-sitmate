// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id        String   @id @default(uuid())
  name      String   @unique
  nameKey   String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  sites     Site[]
  formResponses FormResponse[]
  nonconformanceActions NonconformanceAction[]
  nonconformances Nonconformance[]
  kpiDashboards KpiDashboard[]
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  firstName   String
  lastName    String
  email       String   @unique
  jobTitle    String?
  companyname String?
  mobile      String
  password    String
  role        Role     @default(worker)
  accessMode  AccessMode @default(standard)
  allowedPages Json?
  active      Boolean  @default(true)
  emailVerified Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lastLoginAt DateTime?
  lastSeenAt  DateTime?
  
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  @@index([clientId])

  managedSites Site[] @relation("SitePrimaryManager")
  siteManagerAssignments SiteManager[]
  
  createdForms  Form[]
  submittedResponses FormResponse[]
  uploadedDocuments SiteDocument[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  savedSignatures SavedSignature[]
  updatedKpiDashboards KpiDashboard[] @relation("KpiDashboardUpdatedBy")
  assignedNonconformances NonconformanceAction[] @relation("NonconformanceAssignee")
  reportedNonconformances NonconformanceAction[] @relation("NonconformanceReporter")
  notifications UserNotification[]
  assignedNcRecords Nonconformance[] @relation("NcAssignee")
  reportedNcRecords Nonconformance[] @relation("NcReporter")
  submittedNcResponses NcResponse[] @relation("NcResponseSubmitter")
  ncHistoryEntries NcHistory[] @relation("NcHistoryActor")
  ncNotifications Notification[] @relation("NcNotificationUser")
}

model SavedSignature {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("")
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model KpiDashboard {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  section     String
  payload     Json
  updatedById String?
  updatedBy   User?    @relation("KpiDashboardUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, section])
  @@index([clientId])
}

model EmailVerificationToken {
  id           String    @id @default(uuid())
  tokenHash    String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  usedAt       DateTime?
  otpHash      String?
  otpExpiresAt DateTime?
  kind         String    @default("standard")
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([kind])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetAttempt {
  id        String   @id @default(uuid())
  emailHash String
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([emailHash, createdAt])
  @@index([ipHash, createdAt])
}

model Site {
  id        String   @id @default(uuid())
  name      String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])

  managerId String?
  manager   User?   @relation("SitePrimaryManager", fields: [managerId], references: [id])

  siteManagers SiteManager[]

  documents  SiteDocument[]
  subfolders SiteSubfolder[]

  @@index([clientId])
  @@index([createdAt])
  @@index([managerId])
  @@index([isActive])
}

model SiteSubfolder {
  id        String   @id @default(uuid())
  name      String
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  // Null = Friday Pack; set to ohs/environmental/etc. for monitoring-only folders
  monitoringSection String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents SiteDocument[]

  @@index([siteId])
  @@index([siteId, monitoringSection])
}

model SiteManager {
  siteId String
  userId String
  site   Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([siteId, userId])
  @@index([userId])
}

model Form {
  id             String   @id @default(uuid())
  title          String   @default("Untitled Form")
  titleColor     String   @default("#000000")
  titleAlignment String   @default("left")
  fields         Json     // Stores the array of form fields
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  responses FormResponse[]
}

model FormResponse {
  id          String   @id @default(uuid())
  answers     Json     // Stores the answers object
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formId String
  form   Form   @relation(fields: [formId], references: [id])

  submittedById String?
  submittedBy   User?   @relation(fields: [submittedById], references: [id])
  nonconformance Nonconformance?

  /// Company at submit time — kept when the submitter later changes company.
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  siteId      String?
  subfolderId String?

  @@index([createdAt])
  @@index([category])
  @@index([submittedById])
  @@index([formId])
  @@index([submittedById, createdAt])
  @@index([clientId])
  @@index([siteId])
  @@index([subfolderId])
  @@index([siteId, subfolderId])
}

enum Role {
  superadmin
  company_admin
  site_manager
  supervisor
  worker
}

enum AccessMode {
  standard
  view_only
}

enum NonconformanceStatus {
  pending
  assigned
  draft
  sent
  response_submitted
  under_review
  reopened
  closed
}

enum NonconformancePriority {
  low
  medium
  high
  critical
}

enum NcHistoryAction {
  created
  assigned
  draft_saved
  response_submitted
  under_review
  reopened
  rejection_reason
  accepted
  closed
  notification_sent
  email_sent
  admin_override
}

enum NcNotificationType {
  assigned
  response_submitted
  rejected_reopened
  accepted_closed
}

enum NonconformanceRegisterStatus {
  open
  closed
  accepted
  rejected
}

model NonconformanceAction {
  id               String               @id @default(uuid())
  formResponseId   String?
  assigneeId       String
  reporterId       String
  clientId         String
  status           NonconformanceStatus @default(pending)
  registerStatus   NonconformanceRegisterStatus @default(open)
  title            String
  correctionAction String               @default("")
  responsibleEmail String?
  responsibleName  String?
  dateCompleted    String?
  details          Json                 @default("{}")
  groupKey         String?
  responseNotes    String?
  draftData        Json?
  sentAt           DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  assignee User @relation("NonconformanceAssignee", fields: [assigneeId], references: [id])
  reporter User @relation("NonconformanceReporter", fields: [reporterId], references: [id])
  client   Client @relation(fields: [clientId], references: [id])

  @@index([assigneeId, status])
  @@index([reporterId])
  @@index([clientId])
  @@index([groupKey, createdAt])
}

model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Nonconformance {
  id                   String                   @id @default(uuid())
  ncNumber             String                   @unique @map("nc_number")
  title                String
  description          String
  category             String
  priority             NonconformancePriority  @default(medium)
  reporterId           String                   @map("reporter_id")
  assigneeId           String                   @map("assignee_id")
  clientId             String                   @map("client_id")
  dueDate              DateTime                 @map("due_date") @db.Date
  status               NonconformanceStatus     @default(assigned)
  closedAt             DateTime?                @map("closed_at")
  sourceFormResponseId String?                  @unique @map("source_form_response_id")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  reporter    User           @relation("NcReporter", fields: [reporterId], references: [id])
  assignee    User           @relation("NcAssignee", fields: [assigneeId], references: [id])
  client      Client         @relation(fields: [clientId], references: [id])
  sourceFormResponse FormResponse? @relation(fields: [sourceFormResponseId], references: [id], onDelete: SetNull)
  responses   NcResponse[]
  history     NcHistory[]
  notifications Notification[]

  @@index([assigneeId, status])
  @@index([reporterId, status])
  @@index([clientId, status])
  @@index([clientId, dueDate])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
  @@map("nonconformances")
}

model NcResponse {
  id               String    @id @default(uuid())
  nonconformanceId String    @map("nonconformance_id")
  correctionDone   String    @map("correction_done")
  rootCause        String    @map("root_cause")
  correctiveAction String    @map("corrective_action")
  isDraft          Boolean   @default(true) @map("is_draft")
  version          Int
  submittedById    String    @map("submitted_by")
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  nonconformance Nonconformance @relation(fields: [nonconformanceId], references: [id], onDelete: Cascade)
  submittedBy    User           @relation("NcResponseSubmitter", fields: [submittedById], references: [id])
  attachments    NcAttachment[]

  @@unique([nonconformanceId, version])
  @@index([nonconformanceId, isDraft])
  @@map("nc_responses")
}

model NcAttachment {
  id         String   @id @default(uuid())
  responseId String   @map("response_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  mimeType   String   @map("mime_type")
  fileSize   Int?     @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at")

  response NcResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@map("nc_attachments")
}

model NcHistory {
  id               String          @id @default(uuid())
  nonconformanceId String          @map("nonconformance_id")
  action           NcHistoryAction
  actorId          String          @map("actor_id")
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")

  nonconformance Nonconformance @relation(fields: [nonconformanceId], references: [id], onDelete: Cascade)
  actor          User           @relation("NcHistoryActor", fields: [actorId], references: [id])

  @@index([nonconformanceId, createdAt])
  @@map("nc_history")
}

model Notification {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  nonconformanceId String             @map("nonconformance_id")
  type             NcNotificationType
  message          String
  isRead           Boolean            @default(false) @map("is_read")
  createdAt        DateTime           @default(now()) @map("created_at")

  user           User           @relation("NcNotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  nonconformance Nonconformance @relation(fields: [nonconformanceId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SiteDocument {
  id          String   @id @default(uuid())
  title       String
  type        String // PDF, DOC, etc.
  version     String
  url         String
  size        String
  category    String // rams, friday-pack, etc.
  tags        String?
  validFrom   String?
  validUntil  String
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  subfolderId String?
  subfolder   SiteSubfolder? @relation(fields: [subfolderId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId])
  @@index([subfolderId])
}
