// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(uuid())
  name      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  sites     Site[]
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  firstName   String
  lastName    String
  email       String   @unique
  jobTitle    String?
  companyname String?
  mobile      String
  password    String
  role        Role     @default(worker)
  active      Boolean  @default(true)
  emailVerified Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lastLoginAt DateTime?
  lastSeenAt  DateTime?
  
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  @@index([clientId])

  managedSites Site[] @relation("SitePrimaryManager")
  siteManagerAssignments SiteManager[]
  
  createdForms  Form[]
  submittedResponses FormResponse[]
  uploadedDocuments SiteDocument[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Site {
  id        String   @id @default(uuid())
  name      String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])

  managerId String?
  manager   User?   @relation("SitePrimaryManager", fields: [managerId], references: [id])

  siteManagers SiteManager[]

  documents SiteDocument[]
}

model SiteManager {
  siteId String
  userId String
  site   Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([siteId, userId])
  @@index([userId])
}

model Form {
  id             String   @id @default(uuid())
  title          String   @default("Untitled Form")
  titleColor     String   @default("#000000")
  titleAlignment String   @default("left")
  fields         Json     // Stores the array of form fields
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  responses FormResponse[]
}

model FormResponse {
  id          String   @id @default(uuid())
  answers     Json     // Stores the answers object
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formId String
  form   Form   @relation(fields: [formId], references: [id])

  submittedById String?
  submittedBy   User?   @relation(fields: [submittedById], references: [id])

  @@index([createdAt])
  @@index([category])
  @@index([submittedById])
  @@index([formId])
  @@index([submittedById, createdAt])
}

enum Role {
  superadmin
  company_admin
  site_manager
  supervisor
  worker
}

model SiteDocument {
  id          String   @id @default(uuid())
  title       String
  type        String // PDF, DOC, etc.
  version     String
  url         String
  size        String
  category    String // rams, friday-pack, etc.
  tags        String?
  validFrom   String?
  validUntil  String
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
