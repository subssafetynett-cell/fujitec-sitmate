# Copy to `.env` in the project root for Docker Compose (same file `docker-compose.yaml`
# references via `env_file`). Never commit `.env` with real passwords.
#
# Compose files:
#   - `docker-compose.yaml` — no host port binds (Coolify / shared hosts).
#   - `docker-compose.local.yaml` — adds localhost:8080 / :4000 / :5434 (Postgres); merged by `scripts/docker-up.sh`.
#
# Coolify / production: set DATABASE_URL and JWT_SECRET for the backend. If DATABASE_URL is
# missing, the API container exits during startup (entrypoint fails fast).

# --- Neon (or any external Postgres) ---
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Local default (omit DATABASE_URL when using bundled Postgres in docker-compose.yaml) ---
# DATABASE_URL=postgresql://safetyuser:safetypassword@db:5432/safetyapp_db?schema=public

# --- HTTPS / reverse proxy (backend) ---
# NODE_ENV=production
# TRUST_PROXY=1
# Public URL of the web app (password reset + welcome emails). No trailing slash.
# APP_URL=https://site-mateai.co.uk
# BASE_URL=   # optional alias for APP_URL
# Comma-separated browser origins allowed to call the API (your public SPA URL(s)):
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# --- Frontend Docker build (HTTPS) ---
# Same-origin API through nginx (recommended when TLS terminates at your edge / nginx):
#   VITE_USE_RELATIVE_API=true
# Separate API host (must be https in production if the SPA is https):
#   VITE_USE_RELATIVE_API=false
#   VITE_BACKEND_URL=https://api.example.com
# App served under a subpath (optional):
#   VITE_BASE_PATH=/safety/

# --- First superadmin (created on each backend container start if missing) ---
# Defaults: admin@safetynet.com / AdminPass1! — change in production (Coolify env).
# SUPERADMIN_EMAIL=you@yourcompany.com
# SUPERADMIN_PASSWORD=YourSecurePass1!
# SUPERADMIN_RESET_PASSWORD=true   # only when you need to reset an existing superadmin password

# Local disk uploads (optional; default is ./uploads in Docker, /tmp/uploads on Vercel/serverless)
# UPLOADS_DIR=/app/uploads

# Add your other backend secrets here (JWT, Cloudinary, etc.) as needed by server.js.
